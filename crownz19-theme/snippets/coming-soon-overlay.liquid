{%- comment -%}
  Coming Soon overlay for products tagged with "coming-soon"
  Usage: {% render 'coming-soon-overlay' %}
{%- endcomment -%}

<div class="coming-soon-overlay">
  <span class="coming-soon-overlay__label">Coming Soon</span>
</div>

<style>
  .coming-soon-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    background-color: rgba(232, 228, 220, 0.5);
    z-index: 2;
    border-radius: inherit;
  }

  .coming-soon-overlay__label {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--crownz-black);
    padding: 6px 16px;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 2px;
    background-color: rgba(255, 255, 255, 0.6);
  }
</style>
