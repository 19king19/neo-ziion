{%- liquid
  assign limit = section.settings.limit | default: 4
  assign heading = section.settings.heading
-%}

{%- if recommendations.performed and recommendations.products_count > 0 -%}
<section class="related-products">
  <div class="related-products__inner">
    {%- if heading != blank -%}
      <h2 class="related-products__heading">{{ heading }}</h2>
    {%- endif -%}

    <div class="related-products__grid">
      {%- for product in recommendations.products limit: limit -%}
        <div class="related-products__item">
          {%- render 'product-card', product: product -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

<style>
  .related-products {
    padding: var(--spacing-3xl) 0;
    background: var(--crownz-white);
    border-top: 1px solid rgba(10, 10, 10, 0.06);
  }
  .related-products__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }
  .related-products__heading {
    font-size: 1.4rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 var(--spacing-2xl);
    color: var(--crownz-black);
  }
  .related-products__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-lg);
  }
  @media (max-width: 768px) {
    .related-products__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Related Products",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Products to show",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Related Products"
    }
  ]
}
{% endschema %}
