{%- liquid
  assign image = section.settings.image
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign btn_text = section.settings.button_text
  assign btn_link = section.settings.button_link
  assign height = section.settings.height
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
-%}

<section class="hero-banner hero-banner--{{ height }}" data-hero-banner>
  {%- if image != blank -%}
    <div class="hero-banner__bg">
      <img
        src="{{ image | image_url: width: 1920 }}"
        alt="{{ image.alt | escape }}"
        width="1920"
        height="{{ 1920 | divided_by: image.aspect_ratio }}"
        loading="eager"
        class="hero-banner__bg-img"
      >
      <div class="hero-banner__overlay" style="opacity: {{ overlay_opacity }}"></div>
    </div>
  {%- endif -%}

  <div class="hero-banner__content">
    {%- if heading != blank -%}
      <h1 class="hero-banner__heading">{{ heading }}</h1>
    {%- endif -%}
    {%- if subheading != blank -%}
      <p class="hero-banner__sub">{{ subheading }}</p>
    {%- endif -%}
    {%- if btn_text != blank -%}
      <a href="{{ btn_link }}" class="btn btn--primary hero-banner__btn">{{ btn_text }}</a>
    {%- endif -%}
  </div>
</section>

<style>
  .hero-banner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--crownz-white);
    overflow: hidden;
  }
  .hero-banner--small { min-height: 50vh; }
  .hero-banner--medium { min-height: 70vh; }
  .hero-banner--large { min-height: 100vh; }
  .hero-banner__bg { position: absolute; inset: 0; z-index: 0; }
  .hero-banner__bg-img { width: 100%; height: 100%; object-fit: cover; }
  .hero-banner__overlay {
    position: absolute; inset: 0;
    background: var(--crownz-black, #0a0a0a);
  }
  .hero-banner__content {
    position: relative; z-index: 2;
    max-width: 700px; padding: var(--spacing-2xl) var(--spacing-lg);
  }
  .hero-banner__heading {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 200;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0 0 var(--spacing-md);
  }
  .hero-banner__sub {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255,255,255,0.6);
    margin: 0 0 var(--spacing-xl);
  }
  .hero-banner__btn { border-color: var(--crownz-white); color: var(--crownz-white); }
  .hero-banner__btn:hover { background: var(--crownz-white); color: var(--crownz-black); }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CROWNZ19"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Wear the crown. Own the legacy."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "small", "label": "Small (50vh)" },
        { "value": "medium", "label": "Medium (70vh)" },
        { "value": "large", "label": "Full screen" }
      ],
      "default": "large"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay darkness",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
