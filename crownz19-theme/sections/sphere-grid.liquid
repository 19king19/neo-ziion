{%- liquid
  assign bg_color = section.settings.background_color | default: '#0a0a0a'
-%}

<section
  class="sphere-grid"
  data-sphere-grid
  style="background-color: {{ bg_color }};"
  aria-label="{{ section.settings.heading | default: 'Explore' }}"
>
  {%- if section.settings.heading != blank -%}
    <div class="sphere-grid__header">
      <h2 class="sphere-grid__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="sphere-grid__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="sphere-grid__grid" data-sphere-grid-container>
    {%- for block in section.blocks -%}
      {%- render 'sphere-item', block: block -%}
    {%- endfor -%}
  </div>
</section>

{{ 'crownz19-sphere-grid.css' | asset_url | stylesheet_tag }}
<script src="{{ 'crownz19-sphere-grid.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Sphere Grid",
  "tag": "div",
  "class": "sphere-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0a0a0a"
    }
  ],
  "blocks": [
    {
      "type": "sphere",
      "name": "Sphere",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Concept"
        },
        {
          "type": "image_picker",
          "id": "sphere_image",
          "label": "Sphere image",
          "info": "Displayed inside the orb. Ideally a dark, textured image."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sphere Grid",
      "settings": {
        "background_color": "#0a0a0a"
      },
      "blocks": [
        { "type": "sphere", "settings": { "label": "Sleep" } },
        { "type": "sphere", "settings": { "label": "Energy" } },
        { "type": "sphere", "settings": { "label": "Mind" } },
        { "type": "sphere", "settings": { "label": "Joy" } },
        { "type": "sphere", "settings": { "label": "Gratitude" } },
        { "type": "sphere", "settings": { "label": "Confidence" } },
        { "type": "sphere", "settings": { "label": "Anger" } },
        { "type": "sphere", "settings": { "label": "Anxiety" } },
        { "type": "sphere", "settings": { "label": "Stress" } },
        { "type": "sphere", "settings": { "label": "Connection" } },
        { "type": "sphere", "settings": { "label": "Purpose" } },
        { "type": "sphere", "settings": { "label": "Focus" } }
      ]
    }
  ],
  "max_blocks": 16
}
{% endschema %}
