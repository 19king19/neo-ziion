{%- if section.settings.show_announcement -%}
  <div class="announcement-bar" role="region" aria-label="{{ 'accessibility.announcement' | t }}">
    <div class="announcement-bar__inner">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__link">
          {{ section.settings.text | default: 'Welcome to CROWNZ19' }}
        </a>
      {%- else -%}
        <p class="announcement-bar__text">
          {{ section.settings.text | default: 'Welcome to CROWNZ19' }}
        </p>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free shipping on orders over $100"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f5f3ef"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}

<style>
  .announcement-bar {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 8px 0;
    text-align: center;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .announcement-bar__inner {
    max-width: var(--page-width, 1400px);
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .announcement-bar__link {
    color: inherit;
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .announcement-bar__link:hover {
    opacity: 0.7;
  }

  .announcement-bar__text {
    margin: 0;
  }
</style>
