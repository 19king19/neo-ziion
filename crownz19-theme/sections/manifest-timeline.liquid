          "settings": {
            "era_title": "Celestial Origins",
            "era_period": "Before Time",
            "accent_color": "#d4af37"
          }
        },
        {
          "type": "era",
          "settings": {
            "era_title": "Ancient Kemet",
            "era_period": "c. 3000 BCE",
            "accent_color": "#c8a96e"
          }
        },
        {
          "type": "era",
          "settings": {
            "era_title": "Indigenous Americas",
            "era_period": "c. 1200 BCE – 1500 CE",
            "accent_color": "#8b6914"
          }
        },
        {
          "type": "era",
          "settings": {
            "era_title": "Moorish Empire",
            "era_period": "711 – 1492 CE",
            "accent_color": "#a0522d"
          }
        },
        {
          "type": "era",
          "settings": {
            "era_title": "Islamic Golden Age",
            "era_period": "8th – 14th Century",
            "accent_color": "#1a7a4c"
          }
        },
        {
          "type": "era",
          "settings": {
            "era_title": "West African Kingdoms",
            "era_period": "c. 1000 – 1900 CE",
            "accent_color": "#d4a017"
          }
        },
        {
          "type": "era",
          "settings": {
            "era_title": "East African Traditions",
            "era_period": "c. 100 – 1974 CE",
            "accent_color": "#8b4513"
          }
        },
        {
          "type": "era",
          "settings": {
            "era_title": "Caribbean & Diaspora",
            "era_period": "16th Century – Present",
            "accent_color": "#4a90d9"
          }
        },
        {
