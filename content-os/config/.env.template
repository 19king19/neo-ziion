# ═══════════════════════════════════════════
# Sovereign Content OS — Environment Config
# Copy to .env and fill in your keys
# ═══════════════════════════════════════════

# Google APIs
GOOGLE_CREDENTIALS_PATH=./config/google_credentials.json
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# YouTube
YOUTUBE_CHANNEL_ID=your_channel_id_here

# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Twitter/X API (for autonomous posting agent)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Whisper
WHISPER_MODEL=medium

# Vault paths
VAULT_RAW=./vault/raw
VAULT_TRANSCRIPTS=./vault/transcripts
VAULT_INTELLIGENCE=./vault/intelligence

# Status server
STATUS_PORT=8819
STATUS_HOST=0.0.0.0

# Schedule intervals (minutes)
GDRIVE_SYNC_INTERVAL=15
YT_ANALYTICS_INTERVAL=60
INTELLIGENCE_INTERVAL=30
