{%- liquid
  assign total_eras = section.blocks.size
-%}

<section class="manifest-timeline" data-manifest-timeline aria-label="{{ section.settings.heading | default: 'The Manifest' }}">
  {%- comment -%} Fixed intro overlay {%- endcomment -%}
  {%- if section.settings.show_intro -%}
    <div class="manifest-timeline__intro" data-manifest-intro>
      <div class="manifest-timeline__intro-content">
        <h2 class="manifest-timeline__intro-heading">{{ section.settings.heading | default: 'The Manifest' }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="manifest-timeline__intro-sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <div class="manifest-timeline__scroll-hint">
          <span>Scroll to explore</span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Progress bar {%- endcomment -%}
  <div class="manifest-timeline__progress" data-manifest-progress>
    <div class="manifest-timeline__progress-bar" data-manifest-progress-bar></div>
    <div class="manifest-timeline__progress-dots">
      {%- for block in section.blocks -%}
        <button
          class="manifest-timeline__dot"
          data-manifest-dot="{{ forloop.index }}"
          aria-label="Go to {{ block.settings.era_title }}"
        >
          <span class="manifest-timeline__dot-label">{{ block.settings.era_title | truncate: 15 }}</span>
        </button>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Horizontal scroll track {%- endcomment -%}
  <div class="manifest-timeline__track" data-manifest-track>
    <div class="manifest-timeline__scroll" data-manifest-scroll style="width: {{ total_eras | times: 100 }}vw;">
      {%- for block in section.blocks -%}
        {%- render 'timeline-era', block: block, index: forloop.index -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{{ 'crownz19-manifest.css' | asset_url | stylesheet_tag }}
<script src="{{ 'crownz19-manifest.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Manifest Timeline",
  "tag": "div",
  "class": "manifest-timeline-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Manifest"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A journey through the sacred lineage of the crown — from celestial origins to modern legacy."
    },
    {
      "type": "checkbox",
      "id": "show_intro",
      "label": "Show intro screen",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "era",
      "name": "Era",
      "settings": [
        {
          "type": "text",
          "id": "era_title",
          "label": "Era title",
          "default": "Era Title"
        },
        {
          "type": "text",
          "id": "era_period",
          "label": "Time period",
          "default": "c. 3000 BCE"
        },
        {
          "type": "richtext",
          "id": "era_description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "era_image",
          "label": "Era artifact image",
          "info": "Crown or cultural artifact for this era"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Accent color",
          "default": "#c8a96e"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Manifest Timeline",
      "settings": {
        "heading": "The Manifest",
        "subheading": "A journey through the sacred lineage of the crown — from celestial origins to modern legacy."
      },
      "blocks": [
        {
