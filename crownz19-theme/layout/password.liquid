<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600&display=swap" rel="stylesheet">
  {{ 'crownz19-base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  <style>
    .password-page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: var(--crownz-black);
      color: var(--crownz-text-light);
      text-align: center;
      padding: var(--space-xl);
    }
    .password-page__logo {
      font-size: 1.5rem;
      font-weight: var(--weight-bold);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: var(--space-3xl);
    }
    .password-page h1 {
      font-weight: var(--weight-light);
      margin-bottom: var(--space-lg);
    }
    .password-page p {
      color: var(--crownz-text-muted);
      margin-bottom: var(--space-2xl);
    }
    .password-page__form {
      display: flex;
      gap: var(--space-sm);
      max-width: 400px;
      width: 100%;
    }
    .password-page__input {
      flex: 1;
      padding: 14px 20px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      color: var(--crownz-text-light);
      font-size: 0.875rem;
    }
    .password-page__input::placeholder { color: var(--crownz-text-muted); }
  </style>
</head>
<body>
  <div class="password-page">
    <div class="password-page__logo">CROWNZ19</div>
    {{ content_for_layout }}
  </div>
</body>
</html>
