{%- liquid
  assign heading = section.settings.heading
  assign text = section.settings.text
-%}

<section class="newsletter-section">
  <div class="newsletter-section__inner">
    {%- if heading != blank -%}
      <h2 class="newsletter-section__heading">{{ heading }}</h2>
    {%- endif -%}
    {%- if text != blank -%}
      <p class="newsletter-section__text">{{ text }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'newsletter-section__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p class="newsletter-section__success">{{ 'newsletter.success' | t }}</p>
      {%- endif -%}
      <div class="newsletter-section__field">
        <input
          type="email"
          name="contact[email]"
          placeholder="{{ 'newsletter.placeholder' | t }}"
          required
          class="newsletter-section__input"
          aria-label="{{ 'newsletter.placeholder' | t }}"
        >
        <button type="submit" class="newsletter-section__btn btn btn--primary">
          {{ 'newsletter.submit' | t }}
        </button>
      </div>
    {%- endform -%}
  </div>
</section>

<style>
  .newsletter-section {
    padding: var(--spacing-3xl) 0;
    background: var(--crownz-black, #0a0a0a);
    color: var(--crownz-white);
    text-align: center;
  }
  .newsletter-section__inner {
    max-width: 550px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }
  .newsletter-section__heading {
    font-size: 1.6rem;
    font-weight: 200;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 var(--spacing-sm);
  }
  .newsletter-section__text {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    margin: 0 0 var(--spacing-xl);
  }
  .newsletter-section__field {
    display: flex;
    gap: 0;
  }
  .newsletter-section__input {
    flex: 1;
    padding: 14px 16px;
    font-size: 0.9rem;
    border: 1px solid rgba(255,255,255,0.15);
    border-right: none;
    background: transparent;
    color: var(--crownz-white);
  }
  .newsletter-section__input::placeholder { color: rgba(255,255,255,0.3); }
  .newsletter-section__input:focus { outline: none; border-color: rgba(255,255,255,0.4); }
  .newsletter-section__btn {
    white-space: nowrap;
    border-color: rgba(255,255,255,0.15);
    color: var(--crownz-white);
  }
  .newsletter-section__btn:hover {
    background: var(--crownz-white);
    color: var(--crownz-black);
    border-color: var(--crownz-white);
  }
  .newsletter-section__success {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--spacing-md);
  }
  @media (max-width: 480px) {
    .newsletter-section__field { flex-direction: column; gap: var(--spacing-sm); }
    .newsletter-section__input { border-right: 1px solid rgba(255,255,255,0.15); }
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Legacy"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Subscribe for early access to new drops, exclusive offers, and updates from CROWNZ19."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
